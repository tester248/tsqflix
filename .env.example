# tsqflix unified env template
#
# Populate the variables below and then copy or source this file when you start the
# backend (e.g. `set -a && source .env.example && npm start`) and when you run the
# frontend (copy the relevant keys into `frontend/.env.local`).

## Backend / server
API_PORT=3000
CHILD_MODE=0
FEBBOX_UI_COOKIE=replace-with-your-febbox-ui-cookie

## Frontend / Next.js
TMDB_KEY=replace-with-your-tmdb-api-key
TMDB_READ_ACCESS_TOKEN=replace-with-your-read-access-token
GA_ID=G-XXXXXXXXXX # optional (used by the frontend layout for analytics)
NEXT_PUBLIC_TSQFLIX_API_URL=http://localhost:3000 # backend URL for Showbox/Febbox streaming
FRONTEND_PORT=3001 # port where Next.js dev server should listen (default now 3001 to avoid the backend)